# Local secrets + per-machine config for the bridge.
# Copy to `.env.local` and fill in. `.env.local` is gitignored.
# bridge.py auto-loads .env.local at import time via python-dotenv.

# ---------------------------------------------------------------------------
# LLM backend — direct OpenAI-compatible chat completions.
# Default: OpenRouter + Sonnet 4.6. Swap freely by changing URL + model.
# ---------------------------------------------------------------------------

# OpenRouter (default)
LLM_API_URL=https://openrouter.ai/api/v1/chat/completions
LLM_MODEL=anthropic/claude-sonnet-4-6
LLM_API_KEY=sk-or-v1-REPLACE_ME

# Alternate: OpenAI cloud
# LLM_API_URL=https://api.openai.com/v1/chat/completions
# LLM_MODEL=gpt-4o-mini
# LLM_API_KEY=sk-REPLACE_ME

# Alternate: LM Studio (local, no key needed but field can't be empty)
# LLM_API_URL=http://localhost:1234/v1/chat/completions
# LLM_MODEL=local-model
# LLM_API_KEY=lm-studio

# Alternate: Ollama (local)
# LLM_API_URL=http://localhost:11434/v1/chat/completions
# LLM_MODEL=llama3.1:8b
# LLM_API_KEY=ollama

# How long to wait for the LLM before timing out the turn (seconds).
LLM_TIMEOUT=60
LLM_MAX_TOKENS=512

# ---------------------------------------------------------------------------
# ASR — xiaozhi-esp32-server (in Docker) does the speech-to-text. Default
# config uses OpenaiASR which needs an OpenAI cloud key. Cheap (~$0.006/min)
# but not free. Swap to FunASR/SenseVoiceSmall later for fully local STT.
# ---------------------------------------------------------------------------
OPENAI_API_KEY=sk-REPLACE_ME

# ---------------------------------------------------------------------------
# Persona — picks which file in personas/ becomes the system prompt.
# ---------------------------------------------------------------------------
PERSONA=feisty

# ---------------------------------------------------------------------------
# Locale — bridge uses this for date/time/calendar context injection.
# ---------------------------------------------------------------------------
TZ=America/New_York
WEATHER_LOCATION=

# ---------------------------------------------------------------------------
# xiaozhi-server endpoints — used by the dashboard for status probes and
# by perception consumers to push commands to the device. Set after the
# device is paired and you know the LAN IP of the machine running the
# xiaozhi-server container (likely this Windows host: 127.0.0.1 if local).
# ---------------------------------------------------------------------------
XIAOZHI_HOST=127.0.0.1
XIAOZHI_OTA_PORT=8003
XIAOZHI_WS_PORT=8000

# ---------------------------------------------------------------------------
# Vision (room-view) — same OpenRouter key by default; uses Gemini for
# cheap multimodal. Skip if you don't want camera-aware turns.
# ---------------------------------------------------------------------------
VISION_MODEL=google/gemini-2.0-flash-001
# VISION_API_KEY=  # falls back to LLM_API_KEY if unset
